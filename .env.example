# ====================================================================
# Politika ve Ekonomi Simulasyonu - Environment Variables Example
# ====================================================================
# Bu dosyayı .env adıyla kopyalayın ve canlı sunucu değerlerinize göre düzenleyin.

# --- SUNUCU GENEL AYARLARI ---
NODE_ENV=production
PORT=3000
JWT_SECRET=SUPER_SECRET_POLITIC_KEY_2026_CHANGE_ME

# --- VERİTABANI (POSTGRESQL) AYARLARI ---
DB_HOST=localhost
DB_PORT=5440
DB_USERNAME=politic_user
DB_PASSWORD=politic_password
DB_DATABASE=politic_db

# --- REDIS AYARLARI ---
REDIS_URL=redis://localhost:6379

# --- OYUN AYARLARI ---
IS_BORDER_FROZEN=false

# --- MOBİL UYGULAMA DERLEME AYARLARI (İSTEĞE BAĞLI) ---
# Mobil uygulama derlenirken canlı sunucu backend adresini belirtmek için:
# EXPO_PUBLIC_API_URL=https://politic.oyunadi.com
