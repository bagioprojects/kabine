{
  "name": "political-simulation-backend",
  "version": "1.0.0",
  "description": "MMO Geopolitical and Macro-economy Simulator",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bullmq": "^4.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-simple": "^0.5.6",
    "multer": "^2.1.1",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.2",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.18",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/jwt-simple": "^0.5.36",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.8.2",
    "eslint": "^8.50.0",
    "prettier": "^3.0.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
